# =============================================================
# Segredos e configuração local — NUNCA versionar
# =============================================================
.env
*.key
*.pem

# =============================================================
# Dados — não versionar (demasiado grandes / sensíveis)
# =============================================================
# Bloqueia o conteúdo das pastas, mas permite ler a raiz delas
data/raw/*
data/staging/*
data/gold/*
data/metrics_quality/*

# Bloqueia extensões globais de dados
*.json.gz
*.parquet
*.csv
*.json

# REGRAS DE EXCEÇÃO: Forçar o Git a guardar os ficheiros .gitkeep
!.gitkeep
!data/raw/.gitkeep
!data/staging/.gitkeep
!data/gold/.gitkeep
!data/metrics_quality/.gitkeep

# Excepção: ficheiros de amostra pequenos para testes
!data/raw/sample/