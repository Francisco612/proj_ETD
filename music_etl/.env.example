# =============================================================
#  Spotify API Credentials
#  Obtém em: https://developer.spotify.com/dashboard
# =============================================================
SPOTIFY_CLIENT_ID=o_teu_client_id_aqui
SPOTIFY_CLIENT_SECRET=o_teu_client_secret_aqui

# =============================================================
#  Caminhos de dados (podes deixar os defaults)
# =============================================================
RAW_DATA_DIR=data/raw
STAGING_DATA_DIR=data/staging
LOGS_DIR=logs

# =============================================================
#  Configuração de extração
# =============================================================
# Número de playlists featured a extrair por chamada (max 50)
SPOTIFY_PLAYLIST_LIMIT=50
# Número de tracks por playlist (max 100)
SPOTIFY_TRACKS_LIMIT=100
# Número de páginas de playlists a extrair (total = LIMIT * PAGES)
SPOTIFY_PLAYLIST_PAGES=5
